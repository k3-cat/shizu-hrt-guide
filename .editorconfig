# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
max_line_length = 100
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_style = tab
indent_size = 2

[package.json]
indent_style = space

[*.html]
indent_style = tab
indent_size = 2

[*.{css,scss}]
indent_style = tab
indent_size = 2

[*.{js,ts,mjs,mts,jsx,tsx,vue}]
indent_style = tab
indent_size = 2
