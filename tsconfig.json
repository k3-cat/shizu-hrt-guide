{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",

		"strict": true,
		"skipLibCheck": true,
		"lib": ["DOM", "ESNext"],

		"declaration": false,
		"noEmitOnError": true,
		"noImplicitAny": false,
		"newLine": "lf"
	},
	"include": ["**/.vuepress/**/*", "./vuepress.config.ts"],
	"exclude": ["node_modules", ".cache", ".temp", "dist"]
}
