{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/*.json",
			"**/*.ts",
			"**/*.tsx",
			"!package.json",
			"!types/worker-configuration.d.ts"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useImportType": {
					"level": "on",
					"options": {
						"style": "separatedType"
					}
				}
			}
		}
	},
	"formatter": {
		"enabled": true,
		"expand": "auto",
		"useEditorconfig": true
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							":NODE:",
							["vite", "vuepress"],
							["vite-*", "vuepress/**", "@vuepress/**", "vuepress-*"],
							":BLANK_LINE:",
							":PACKAGE:",
							":BLANK_LINE:",
							"#/**",
							":BLANK_LINE:",
							"./**"
						]
					}
				}
			}
		}
	}
}
